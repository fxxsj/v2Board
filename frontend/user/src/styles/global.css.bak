:root {
  color-scheme: light;
  font-family: 'Plus Jakarta Sans', 'Inter', 'Segoe UI', sans-serif;
  /* Shared responsive breakpoints:
     desktop = 1200px, tablet = 1024px, mobile = 768px */
  --bp-desktop: 75rem;
  --bp-tablet: 64rem;
  --bp-mobile: 48rem;
  --app-bg: #f3f6fb;
  --app-bg-accent: #eef4ff;
  --surface: rgba(255, 255, 255, 0.86);
  --surface-strong: #ffffff;
  --surface-muted: #f7f9fc;
  --surface-border: rgba(15, 23, 42, 0.08);
  --text-primary: #10203a;
  --text-secondary: #56657f;
  --text-tertiary: #7f8ca3;
  --brand: #1f6fff;
  --brand-strong: #114ed4;
  --brand-soft: rgba(31, 111, 255, 0.12);
  --success-soft: rgba(6, 124, 89, 0.12);
  --warning-soft: rgba(202, 138, 4, 0.14);
  --danger-soft: rgba(220, 38, 38, 0.12);
  --shadow-lg: 0 24px 60px rgba(15, 23, 42, 0.12);
  --shadow-md: 0 18px 40px rgba(15, 23, 42, 0.08);
  --radius-xl: 28px;
  --radius-lg: 22px;
  --radius-md: 16px;
  --content-width: 1200px;
  --content-width-wide: 1280px;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  min-height: 100%;
}

body {
  background:
    radial-gradient(circle at top left, rgba(31, 111, 255, 0.14), transparent 28%),
    radial-gradient(circle at top right, rgba(23, 138, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8fbff 0%, var(--app-bg) 40%, #eff3f8 100%);
  color: var(--text-primary);
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.54) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.54) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4), transparent 80%);
  opacity: 0.35;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  max-width: 100%;
  display: block;
}

.ant-app {
  min-height: 100vh;
}

.ant-typography {
  color: inherit;
}

.app-shell {
  position: relative;
  min-height: 100vh;
}

.app-shell::after {
  content: '';
  position: fixed;
  inset: auto auto 8% -8%;
  width: 320px;
  height: 320px;
  border-radius: 999px;
  background: rgba(31, 111, 255, 0.14);
  filter: blur(48px);
  pointer-events: none;
}

.public-layout {
  background: transparent;
}

.public-header {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  justify-content: center;
  height: auto;
  min-height: 0;
  line-height: normal;
  padding: 20px 24px 0;
  background: linear-gradient(180deg, rgba(243, 246, 251, 0.96) 20%, rgba(243, 246, 251, 0.72) 100%);
  backdrop-filter: blur(18px);
}

.public-header__inner,
.app-layout__content,
.page-section,
.dashboard-shell {
  width: min(100%, var(--content-width));
  margin: 0 auto;
}

.public-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 24px;
  padding: 14px 18px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
  border-radius: 999px;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  gap: 14px;
}

.brand-mark__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: linear-gradient(135deg, #0f4bcf 0%, #3f8cff 100%);
  color: #fff;
  font-size: 18px;
  font-weight: 700;
  box-shadow: 0 14px 28px rgba(31, 111, 255, 0.32);
}

.brand-mark__copy {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.brand-mark__title {
  margin: 0;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.brand-mark__meta {
  color: var(--text-tertiary);
  font-size: 0.8rem;
}

.public-nav {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10px;
}

.public-nav__link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 14px;
  border-radius: 999px;
  color: var(--text-secondary);
  font-weight: 600;
  transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.public-nav__link:hover {
  background: rgba(15, 23, 42, 0.05);
  color: var(--text-primary);
  transform: translateY(-1px);
}

.public-nav__link--active {
  background: rgba(31, 111, 255, 0.1);
  color: var(--brand-strong);
}

.public-nav .ant-btn {
  height: 44px;
  padding-inline: 22px;
  border-radius: 999px;
}

.public-nav__cta a {
  color: inherit;
}

.public-content {
  padding: 28px 24px 56px;
}

.public-footer-note {
  width: min(100%, var(--content-width));
  margin: 36px auto 0;
  padding: 24px 28px;
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.68);
  background: rgba(255, 255, 255, 0.64);
  box-shadow: 0 10px 26px rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(16px);
}

.public-footer-note__grid {
  display: grid;
  gap: 18px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  color: var(--text-secondary);
}

.public-footer-note__label {
  display: block;
  margin-bottom: 8px;
  color: var(--text-tertiary);
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.page-section {
  position: relative;
}

.hero-panel,
.content-panel,
.dashboard-overview,
.login-panel,
.dashboard-card,
.dashboard-highlight,
.metric-tile,
.feature-card,
.config-card {
  border: 1px solid var(--surface-border);
  background: var(--surface);
  backdrop-filter: blur(16px);
  box-shadow: var(--shadow-md);
}

.hero-panel {
  overflow: hidden;
  padding: 36px;
  border-radius: var(--radius-xl);
  background:
    radial-gradient(circle at top right, rgba(31, 111, 255, 0.2), transparent 28%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(245, 248, 255, 0.9));
}

.hero-panel::before {
  content: '';
  position: absolute;
  top: -120px;
  right: -100px;
  width: 260px;
  height: 260px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(31, 111, 255, 0.2), transparent 70%);
}

.hero-grid,
.login-grid {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 28px;
}

.hero-grid {
  grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
  align-items: center;
}

.hero-copy__eyebrow,
.section-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.7);
  color: var(--brand-strong);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.hero-copy__title,
.login-panel__title,
.dashboard-overview__title {
  margin: 18px 0 14px;
  font-size: clamp(2.4rem, 4vw, 4.2rem);
  line-height: 1.02;
  letter-spacing: -0.04em;
}

.hero-copy__title span,
.dashboard-overview__title span,
.login-panel__title span {
  color: var(--brand);
}

.hero-copy__text,
.section-copy,
.login-panel__text,
.dashboard-overview__text {
  max-width: 56ch;
  margin-bottom: 0;
  color: var(--text-secondary);
  font-size: 1.02rem;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 28px;
}

.hero-actions .ant-btn,
.login-panel .ant-btn,
.dashboard-overview .ant-btn {
  height: 48px;
  padding-inline: 20px;
  border-radius: 14px;
  font-weight: 700;
}

.hero-stats {
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.metric-tile {
  padding: 18px 18px 16px;
  border-radius: 20px;
}

.metric-tile--compact {
  min-height: 100%;
  background: rgba(255, 255, 255, 0.72);
}

.metric-tile__label {
  margin-bottom: 10px;
  color: var(--text-tertiary);
  font-size: 0.86rem;
  font-weight: 600;
}

.metric-tile__value {
  margin-bottom: 8px;
  font-size: 1.9rem;
  font-weight: 800;
  letter-spacing: -0.04em;
}

.metric-tile__value--sm {
  font-size: 1.35rem;
}

.metric-tile__hint {
  color: var(--text-secondary);
  font-size: 0.92rem;
  line-height: 1.6;
}

.section-stack {
  display: grid;
  gap: 22px;
  margin-top: 28px;
}

.feature-grid,
.dashboard-stats {
  display: grid;
  gap: 18px;
}

.feature-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.feature-card,
.config-card,
.dashboard-card,
.dashboard-highlight {
  border-radius: var(--radius-lg);
}

.feature-card {
  padding: 24px;
}

.feature-card__icon,
.summary-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  margin-bottom: 16px;
  border-radius: 14px;
  background: var(--brand-soft);
  color: var(--brand-strong);
  font-size: 18px;
}

.feature-card h3,
.config-card h3,
.dashboard-card h3,
.dashboard-highlight h3 {
  margin: 0 0 10px;
  font-size: 1.08rem;
  letter-spacing: -0.02em;
}

.feature-card p,
.config-card p,
.dashboard-card p,
.dashboard-highlight p,
.inline-meta {
  margin: 0;
  color: var(--text-secondary);
  line-height: 1.7;
}

.config-card {
  padding: 28px;
}

.config-grid {
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 22px;
}

.config-item {
  padding: 16px 18px;
  border-radius: 18px;
  background: var(--surface-muted);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.config-item__label {
  display: block;
  margin-bottom: 8px;
  color: var(--text-tertiary);
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.config-item__value {
  color: var(--text-primary);
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-word;
}

.state-alert {
  margin-top: 20px;
  border-radius: 18px;
}

.section-skeleton {
  margin-top: 22px;
}

.login-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 180px);
}

.login-panel {
  width: min(100%, 1040px);
  padding: 18px;
  border-radius: 32px;
}

.login-grid {
  grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
}

.login-panel__intro {
  padding: 28px;
  border-radius: 24px;
  background:
    radial-gradient(circle at top left, rgba(31, 111, 255, 0.16), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
  min-height: 100%;
}

.login-panel__intro-list {
  display: grid;
  gap: 14px;
  margin-top: 28px;
}

.login-panel__intro-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: 16px 18px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(15, 23, 42, 0.06);
}

.login-form-card {
  padding: 30px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(15, 23, 42, 0.08);
}

.section-title {
  margin: 18px 0 8px;
  letter-spacing: -0.03em;
}

.section-title--lg {
  font-size: 1.9rem;
}

.login-form-card .ant-form-item-label > label {
  font-weight: 600;
  color: var(--text-secondary);
}

.app-form {
  margin-top: 24px;
}

.app-form__footer {
  margin-top: 8px;
  margin-bottom: 0;
}

.login-form-card .ant-input-affix-wrapper,
.login-form-card .ant-input {
  min-height: 48px;
  border-radius: 14px;
}

.subtle-link-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 20px;
  color: var(--text-secondary);
  font-size: 0.94rem;
}

.subtle-link-row a {
  color: var(--brand-strong);
  font-weight: 600;
}

.app-layout {
  --app-layout-edge-gap: 20px;
  min-height: 100vh;
  background: transparent;
}

.app-layout .ant-drawer-content,
.app-layout .ant-drawer-body {
  background: transparent;
}

.app-layout__sider {
  flex: 0 0 272px !important;
  max-width: 272px !important;
  min-width: 272px !important;
  position: sticky;
  top: var(--app-layout-edge-gap);
  height: calc(100vh - (var(--app-layout-edge-gap) * 2));
  margin: var(--app-layout-edge-gap) 0 var(--app-layout-edge-gap) var(--app-layout-edge-gap);
  overflow: hidden;
  border-radius: 30px;
  border: 1px solid var(--surface-border);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 250, 255, 0.78)) !important;
  box-shadow: var(--shadow-md);
}

.app-layout__sider .ant-layout-sider-children {
  height: 100%;
}

.app-layout__nav {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.app-layout__brand {
  padding: 22px 22px 10px;
}

.app-layout__section-label {
  padding: 4px 22px 8px;
  color: var(--text-tertiary);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.app-layout__nav .ant-menu {
  padding: 10px 12px 16px;
  background: transparent;
  border-inline-end: 0;
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  overscroll-behavior: contain;
}

.app-layout__nav .ant-menu-item {
  height: 46px;
  margin: 6px 0;
  border-radius: 14px;
  line-height: 46px;
  color: var(--text-secondary);
  font-weight: 600;
}

.app-layout__nav .ant-menu-item-selected {
  background: linear-gradient(135deg, rgba(31, 111, 255, 0.14), rgba(31, 111, 255, 0.08));
  color: var(--brand-strong);
}

.app-layout__sidebar-footer {
  padding: 8px 16px 18px;
  flex: 0 0 auto;
}

.app-layout__sidebar-card {
  display: grid;
  gap: 8px;
  padding: 18px;
  border-radius: 20px;
  background:
    radial-gradient(circle at top right, rgba(31, 111, 255, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(243, 247, 255, 0.9), rgba(255, 255, 255, 0.9));
  border: 1px solid rgba(15, 23, 42, 0.06);
}

.app-layout__sidebar-card-label {
  color: var(--text-tertiary);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.app-layout__sidebar-card strong {
  font-size: 1rem;
  letter-spacing: -0.02em;
}

.app-layout__main {
  background: transparent;
}

.app-layout__header {
  position: sticky;
  top: 0;
  z-index: 18;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  height: auto;
  min-height: 0;
  line-height: normal;
  padding: var(--app-layout-edge-gap) 24px 0;
  background: transparent;
}

.app-layout__header-inner {
  width: min(100%, var(--content-width-wide));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  height: 64px;
  padding: 0 18px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.76);
  border: 1px solid rgba(255, 255, 255, 0.64);
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
  backdrop-filter: blur(14px);
}

.app-layout__menu-trigger {
  display: none;
  width: 36px;
  min-width: 36px;
  height: 36px;
  border-radius: 14px;
  flex: 0 0 auto;
}

.app-layout__headline {
  display: flex;
  align-items: center;
  min-width: 0;
}

.app-layout__headline-title {
  margin: 0;
  font-size: 1.05rem;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.app-layout__header-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
  flex: 0 0 auto;
}

.app-layout__language-select {
  width: 120px;
}

.app-layout__language-select .ant-select-selector {
  height: 36px !important;
  padding-inline: 12px !important;
  border-radius: 14px !important;
  display: flex;
  align-items: center;
}

.app-layout__avatar-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 0;
  border: 0;
  background: transparent;
  cursor: pointer;
}

.app-layout__avatar-link:focus-visible {
  outline: 3px solid rgba(31, 111, 255, 0.32);
  outline-offset: 4px;
}

.app-layout__avatar {
  border: 1px solid rgba(15, 23, 42, 0.08);
}

.app-layout__avatar-dropdown {
  display: grid;
  gap: 4px;
  padding: 8px;
  border-radius: 18px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.12);
  backdrop-filter: blur(16px);
}

.app-layout__avatar-dropdown .ant-btn {
  justify-content: flex-start;
  height: 40px;
  border-radius: 14px;
  font-weight: 650;
}

.app-layout__avatar-dropdown .ant-btn:hover {
  background: rgba(15, 23, 42, 0.05) !important;
}

.app-layout__drawer-root .ant-drawer-mask {
  backdrop-filter: blur(8px);
  background: rgba(15, 23, 42, 0.36);
}

.app-layout__drawer-root .ant-drawer-content-wrapper {
  max-width: calc(100vw - 24px);
}

.app-layout__drawer-root .ant-drawer-content {
  margin: 12px 0 12px 12px;
  border-radius: 28px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(247, 250, 255, 0.92));
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.app-layout__drawer-root .ant-drawer-body {
  padding: 0;
  height: 100%;
}

.app-layout__drawer-body {
  height: 100%;
  min-height: 0;
}

.app-layout__content {
  width: min(100%, var(--content-width-wide));
  padding: 22px 24px 32px;
}

.dashboard-shell {
  width: 100%;
}

.dashboard-overview {
  display: grid;
  gap: 24px;
  grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
  padding: 30px;
  border-radius: 32px;
  background:
    radial-gradient(circle at top right, rgba(31, 111, 255, 0.16), transparent 28%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 255, 0.9));
}

.dashboard-overview__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 22px;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border-radius: 999px;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.84);
  color: var(--text-secondary);
}

.status-pill--primary {
  background: var(--brand-soft);
  color: var(--brand-strong);
}

.dashboard-highlight {
  padding: 24px;
}

.dashboard-highlight__value {
  margin: 12px 0 8px;
  font-size: 2.4rem;
  font-weight: 800;
  letter-spacing: -0.05em;
}

.dashboard-stats {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 22px;
}

.dashboard-card {
  padding: 24px;
}

.summary-value {
  margin: 10px 0 8px;
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -0.05em;
}

.summary-value--compact {
  font-size: 1.35rem;
  line-height: 1.35;
}

.usage-bar {
  height: 10px;
  margin: 16px 0 10px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.08);
}

.usage-bar__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1f6fff 0%, #5ba2ff 100%);
}

.dashboard-grid {
  display: grid;
  gap: 18px;
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
  margin-top: 22px;
}

.dashboard-detail-list {
  display: grid;
  gap: 14px;
  margin-top: 18px;
}

.dashboard-detail-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 18px;
  border-radius: 18px;
  background: var(--surface-muted);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.dashboard-detail-item > :first-child,
.preference-item > :first-child,
.traffic-progress-card__top > :first-child {
  min-width: 0;
}

.dashboard-detail-item__label {
  color: var(--text-tertiary);
  font-size: 0.86rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.dashboard-detail-item__value {
  text-align: right;
  font-weight: 700;
  color: var(--text-primary);
  min-width: 0;
}

.dashboard-detail-item__value--code,
.subscribe-link-box__value {
  font-family: 'JetBrains Mono', 'SFMono-Regular', 'SFMono-Regular', Consolas, monospace;
  font-size: 0.92rem;
  line-height: 1.7;
  word-break: break-all;
}

.dashboard-notice-list {
  display: grid;
  gap: 12px;
  margin-top: 18px;
}

.dashboard-notice {
  padding: 16px 18px;
  border-radius: 18px;
  background: var(--surface-muted);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.dashboard-notice--accent {
  background: linear-gradient(135deg, rgba(31, 111, 255, 0.12), rgba(31, 111, 255, 0.04));
}

.app-card-title {
  display: flex;
  align-items: center;
  gap: 12px;
}

.app-card-title__copy {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.app-card-title__eyebrow {
  color: var(--text-tertiary);
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.account-page-shell {
  display: grid;
  gap: 22px;
}

.account-overview,
.subscribe-overview,
.traffic-overview {
  align-items: stretch;
}

.account-overview__highlight,
.subscribe-overview__highlight,
.traffic-overview__highlight {
  display: grid;
  gap: 18px;
  align-content: start;
}

.traffic-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.account-identity {
  display: flex;
  gap: 16px;
  align-items: center;
}

.account-avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 68px;
  height: 68px;
  border-radius: 22px;
  background: linear-gradient(135deg, #0f4bcf 0%, #58a7ff 100%);
  color: #fff;
  font-size: 1.5rem;
  font-weight: 800;
  box-shadow: 0 18px 32px rgba(31, 111, 255, 0.28);
}

.account-highlight-metrics {
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.account-stats,
.subscribe-stats,
.traffic-stats {
  margin-top: 0;
}

.account-grid,
.subscribe-grid,
.traffic-grid {
  margin-top: 0;
}

.account-side-stack {
  display: grid;
  gap: 18px;
  align-content: start;
}

.preference-list {
  display: grid;
  gap: 12px;
}

.preference-item,
.subscribe-link-box,
.traffic-progress-card {
  padding: 16px 18px;
  border-radius: 18px;
  background: var(--surface-muted);
  border: 1px solid rgba(15, 23, 42, 0.05);
}

.preference-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.preference-item--success {
  background: linear-gradient(135deg, rgba(6, 124, 89, 0.12), rgba(6, 124, 89, 0.04));
}

.subscribe-link-card {
  display: grid;
  gap: 18px;
}

.subscribe-link-box {
  display: grid;
  gap: 16px;
}

.subscribe-guide-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.traffic-progress-card {
  display: grid;
  gap: 14px;
}

.traffic-progress-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.traffic-progress-card__value {
  font-size: 1.8rem;
  font-weight: 800;
  letter-spacing: -0.04em;
}

.ant-btn-primary {
  background: linear-gradient(135deg, var(--brand) 0%, #4d9aff 100%);
  box-shadow: 0 12px 24px rgba(31, 111, 255, 0.24);
}

.ant-btn-primary:not(:disabled):hover {
  background: linear-gradient(135deg, #2e7cff 0%, #62a8ff 100%) !important;
}

.ant-card {
  border-radius: var(--radius-lg);
}

.dashboard-card--full {
  grid-column: 1 / -1;
}

.notice-detail-item {
  flex-direction: column;
  align-items: flex-start;
}

.notice-detail-header {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 8px;
  align-items: center;
}

.notice-detail-title {
  font-size: 1.1rem;
}

.notice-detail-meta {
  margin-bottom: 8px;
}

.notice-detail-expand {
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.notice-detail-expand:hover {
  color: var(--brand-strong) !important;
}

.notice-detail-content {
  width: 100%;
}

.notice-detail-content p {
  margin-bottom: 0;
  color: var(--text-secondary);
}

.server-detail-item {
  flex-direction: column;
  align-items: flex-start;
}

.server-detail-header {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 8px;
  align-items: center;
}

.server-detail-info {
  display: flex;
  align-items: center;
  gap: 12px;
}

.server-detail-info .anticon {
  font-size: 20px;
  color: var(--brand);
}

.device-icon {
  font-size: 20px;
  color: var(--brand);
}

.server-detail-title {
  font-size: 1.1rem;
}

.server-detail-tags {
  display: flex;
  gap: 8px;
}

.server-detail-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 12px;
  width: 100%;
  margin-top: 8px;
}

.server-detail-field {
  min-width: 0;
}

.server-detail-label {
  color: var(--text-tertiary);
  font-size: 0.86rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.server-detail-value {
  font-weight: 700;
  color: var(--text-primary);
}

.server-detail-value--code {
  font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
  font-size: 0.92rem;
  line-height: 1.7;
  word-break: break-all;
}

.server-detail-path {
  margin-top: 12px;
  width: 100%;
}

.server-detail-actions {
  margin-top: 12px;
  display: flex;
  justify-content: flex-end;
}

.session-detail-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.session-detail-modal-notice {
  margin-top: 12px;
}

.ticket-mobile-item.ant-list-item {
  padding: 14px;
  margin-bottom: 12px;
  border: 1px solid var(--surface-border);
  border-radius: 16px;
  background: var(--surface);
  cursor: pointer;
}

.ticket-mobile-item.ant-list-item:hover {
  border-color: color-mix(in srgb, var(--brand) 35%, var(--surface-border));
}

.ticket-mobile-item__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.ticket-mobile-item__subject {
  flex: 1;
  min-width: 0;
  font-size: 1rem;
  line-height: 1.4;
}

.ticket-mobile-item__chevron {
  margin-top: 3px;
  color: var(--text-tertiary);
}

.ticket-mobile-item__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
}

.ticket-mobile-item__priority {
  font-weight: 700;
  color: var(--text-secondary);
}

.ticket-mobile-item__updated {
  font-size: 0.78rem;
  color: var(--text-tertiary);
}

.ticket-modal.ant-modal {
  max-width: 100%;
}

.invite-action-bar {
  margin-top: 18px;
  margin-bottom: 18px;
}

.quick-links {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.quick-links .ant-btn {
  padding: 0;
  height: auto;
  color: var(--brand-strong);
  font-weight: 600;
}

.quick-links .ant-btn:hover {
  color: var(--brand);
}

.security-actions {
  display: grid;
  gap: 10px;
  margin-top: 14px;
}

.security-action-row {
  display: grid;
  gap: 10px;
}

.security-actions .ant-btn {
  justify-content: flex-start;
  height: 40px;
  font-weight: 600;
}

/* Desktop down: 1200px */
@media (max-width: 75rem) {
  .hero-grid,
  .login-grid,
  .dashboard-overview,
  .dashboard-grid {
    grid-template-columns: 1fr;
  }

  .dashboard-stats {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-grid {
    grid-template-columns: 1fr;
  }

  .public-footer-note__grid,
  .subscribe-guide-grid {
    grid-template-columns: 1fr;
  }
}

/* Tablet down: 1024px */
@media (max-width: 64rem) {
  .app-layout {
    --app-layout-edge-gap: 16px;
  }

  .public-header__inner,
  .app-layout__header-inner {
    border-radius: 24px;
  }

  .app-layout__header,
  .app-layout__content {
    padding-inline: 16px;
  }

  .app-layout__header-inner {
    align-items: center;
    padding-inline: 16px;
    gap: 12px;
  }

  .app-layout__headline-title {
    font-size: 1rem;
  }

  .app-layout__language-select {
    width: 104px;
  }

  .app-layout__menu-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    min-width: 32px;
    height: 32px;
  }

  .dashboard-stats,
  .account-highlight-metrics {
    grid-template-columns: 1fr;
  }

  .dashboard-detail-item__value,
  .preference-item .dashboard-detail-item__value {
    text-align: left;
  }
}

/* Mobile down: 768px */
@media (max-width: 48rem) {
  .app-layout {
    --app-layout-edge-gap: 14px;
  }

  .public-header {
    padding: 14px 14px 0;
  }

  .public-header__inner,
  .app-layout__header-inner {
    width: 100%;
  }

  .app-layout__header {
    padding-inline: 12px;
  }

  .app-layout__header-inner {
    padding-inline: 14px;
    border-radius: 16px;
    gap: 10px;
  }

  .app-layout__header-actions {
    gap: 10px;
  }

  .app-layout__language-select {
    width: 96px;
  }

  .app-layout__menu-trigger {
    width: 32px;
    min-width: 32px;
    height: 32px;
  }

  .app-layout__headline-title {
    font-size: 0.95rem;
  }

  .public-nav {
    width: 100%;
    justify-content: stretch;
  }

  .public-nav__link,
  .public-nav .ant-btn {
    flex: 1 1 calc(50% - 10px);
    justify-content: center;
  }

  .public-nav .ant-btn {
    min-width: 0;
  }

  .public-nav .ant-btn,
  .public-nav .ant-btn > span,
  .public-nav__cta a {
    width: 100%;
  }

  .public-content {
    padding-inline: 14px;
  }

  .hero-panel,
  .login-panel,
  .dashboard-overview,
  .dashboard-card,
  .dashboard-highlight,
  .config-card,
  .feature-card {
    padding: 22px;
  }

  .config-grid,
  .account-highlight-metrics {
    grid-template-columns: 1fr;
  }

  .hero-stats {
    grid-template-columns: 1fr;
  }

  .dashboard-overview__meta {
    width: 100%;
  }

  .dashboard-highlight__value,
  .summary-value {
    font-size: 1.8rem;
  }

  .hero-copy__title,
  .login-panel__title,
  .dashboard-overview__title {
    font-size: 2.2rem;
  }

  .ticket-modal.ant-modal {
    width: 100vw !important;
    max-width: 100vw;
    margin: 0;
  }

  .ticket-modal .ant-modal-content {
    border-radius: 0;
  }
}

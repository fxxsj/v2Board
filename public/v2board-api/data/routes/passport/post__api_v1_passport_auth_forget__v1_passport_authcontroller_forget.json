{
  "path": "/api/v1/passport/auth/forget",
  "method": "POST",
  "auth": "guest",
  "description": "忘记密码/重置邮件（passport）",
  "params": [
    {
      "name": "email",
      "type": "email",
      "required": true,
      "rules": [
        "required",
        "email:strict"
      ],
      "source": "FormRequest"
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "rules": [
        "required",
        "min:8"
      ],
      "source": "FormRequest"
    },
    {
      "name": "email_code",
      "type": "string",
      "required": true,
      "rules": [
        "required"
      ],
      "source": "FormRequest"
    }
  ],
  "response": {
    "type": "response([..])",
    "keys": [
      "data"
    ],
    "fields": [
      {
        "field": "data",
        "desc": "主返回数据体"
      }
    ]
  },
  "sample": {
    "status": 422,
    "body": "{\n    \"message\": \"The given data was invalid.\",\n    \"errors\": {\n        \"password\": [\n            \"密码不能为空\"\n        ],\n        \"email_code\": [\n            \"邮箱验证码不能为空\"\n        ]\n    }\n}"
  }
}